<section class="panel">
  <h1>Detail Product</h1>

  {{#if message}}
    <p class="alert alert--success">{{message}}</p>
  {{/if}}

  {{#if error}}
    <p class="alert alert--error">{{error}}</p>
  {{/if}}

  {{#if product}}
    <p class="muted">ID: {{product._id}}</p>

    {{#if product.isDeleted}}
      <p class="alert">Este producto esta eliminado (soft delete). No se permite editar.</p>
    {{/if}}

    <form class="form" action="/products/{{product._id}}?_method=PUT" method="post">
      <label>
        Titulo
        <input type="text" name="title" required minlength="3" value="{{product.title}}" {{#if product.isDeleted}}disabled{{/if}} />
      </label>

      <label>
        Descripcion
        <textarea name="description" rows="4" {{#if product.isDeleted}}disabled{{/if}}>{{product.description}}</textarea>
      </label>

      <div class="form-grid">
        <label>
          Precio
          <input type="number" step="0.01" min="0" name="price" required value="{{product.price}}" {{#if product.isDeleted}}disabled{{/if}} />
        </label>

        <label>
          Stock
          <input type="number" min="0" name="stock" required value="{{product.stock}}" {{#if product.isDeleted}}disabled{{/if}} />
        </label>
      </div>

      <label>
        Categoria
        <input type="text" name="category" value="{{product.category}}" {{#if product.isDeleted}}disabled{{/if}} />
      </label>

      <div class="actions">
        {{#unless product.isDeleted}}
          <button class="button button--primary" type="submit">Guardar cambios</button>
        {{/unless}}
        <a class="button" href="/products">Volver</a>
      </div>
    </form>

    {{#unless product.isDeleted}}
      <form class="inline" action="/products/{{product._id}}?_method=DELETE" method="post">
        <button class="button button--danger" type="submit">Eliminar (soft delete)</button>
      </form>
    {{/unless}}
  {{/if}}
</section>
