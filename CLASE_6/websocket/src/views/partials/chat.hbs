<div class="chatWrapper">
  <aside class="usersPanel">
    <h4>Usuarios conectados</h4>
    <div class="usersContainer"></div>
  </aside>

  <div class="chatContainer">
    <header>
      <h3 class="userName"></h3>
      <p class="typing"></p>
    </header>

    <main>
      <div class="chatMessage"></div>
    </main>

    <footer>
      <input type="text" placeholder="Mensaje..." id="inputMessage" />
      <button id="btnMessage">Enviar</button>
    </footer>
  </div>
</div>